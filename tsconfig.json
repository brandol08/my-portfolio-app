{
  "compileOnSave": false,
  "compilerOptions": {
    "target": "es2015",
    "module": "commonjs",
    "lib": ["es2018", "dom"],
    "rootDir": "./src",
    "outDir": "./out-tsc/app",
    "strict": true,
    "moduleResolution": "node",
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "out-tsc"],
  "serve": {
    "http": "http://localhost:8080"
  }
}